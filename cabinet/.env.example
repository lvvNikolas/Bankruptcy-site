# ─── База данных (Neon Postgres) ──────────────────────────────────────────────
# Получить на: https://console.neon.tech → Connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Генерация: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# URL кабинета (локально или продакшн)
AUTH_URL="http://localhost:3001"
# В продакшне: AUTH_URL="https://cabinet.basolution.ru"

# ─── Email (для отправки приглашений клиентам) ────────────────────────────────
# Можно использовать тот же SMTP что и на основном сайте
SMTP_HOST="smtp.yandex.ru"
SMTP_PORT="465"
SMTP_USER="bankruptcyagencysolution@yandex.com"
SMTP_PASS="your-password"
SMTP_FROM="bankruptcyagencysolution@yandex.com"

# ─── Vercel Blob (для загрузки документов) ────────────────────────────────────
# Получить на: Vercel Dashboard → Storage → Blob → Connect → скопировать токен
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
